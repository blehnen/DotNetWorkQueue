@inherits LayoutComponentBase
@inject DashboardAuthConfig AuthConfig
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_ready)
{
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit">
                <MudText Typo="Typo.h6">DotNetWorkQueue Dashboard</MudText>
            </MudLink>
            <MudSpacer />
            @if (AuthConfig.IsEnabled)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               title="Sign out" OnClick="Logout" />
            }
        </MudAppBar>
        <MudMainContent Class="pa-4">
            @Body
        </MudMainContent>
    </MudLayout>
}

@code {
    private bool _ready;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976d2",
            Secondary = "#424242",
            AppbarBackground = "#1976d2"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#90caf9",
            Secondary = "#ce93d8",
            AppbarBackground = "#1e1e2d"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        if (!AuthConfig.IsEnabled)
        {
            _ready = true;
            return;
        }

        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated ?? false)
            _ready = true;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && AuthConfig.IsEnabled && !_ready)
            Nav.NavigateTo("/login", forceLoad: true);
    }

    private void Logout() => Nav.NavigateTo("/auth/logout", forceLoad: true);
}

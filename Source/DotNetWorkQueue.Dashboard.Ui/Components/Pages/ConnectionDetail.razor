@page "/source/{SourceSlug}/connections/{ConnectionId:guid}"
@inject IMultiSourceDashboardApiClient MultiSourceClient
@inject ISourceRegistry SourceRegistry
@inject NavigationManager Navigation

<PageTitle>Dashboard - Connection</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

@if (_sourceError)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Source "@SourceSlug" not found.
        <MudLink Href="/">Return to source list</MudLink>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadData">Retry</MudButton>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-2">Queues</MudText>

    @if (_queues == null || _queues.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">No queues found for this connection.</MudAlert>
    }
    else
    {
        <MudSimpleTable Elevation="2" Dense="true" Hover="true" Class="mb-6 cursor-pointer">
            <thead>
                <tr>
                    <th>Queue</th>
                    <th>Consumers</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var queue in _queues)
                {
                    <tr @onclick="() => NavigateToQueue(queue)">
                        <td>
                            <MudIcon Icon="@Icons.Material.Filled.Queue" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                            @queue.QueueName
                        </td>
                        <td>
                            @{
                                var count = GetConsumerCount(queue.Id);
                            }
                            @if (count > 0)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">
                                    @count
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">0</MudText>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    <MudText Typo="Typo.h5" Class="mb-2">Scheduled Jobs</MudText>

    @if (_jobs == null || _jobs.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No scheduled jobs found for this connection.</MudAlert>
    }
    else
    {
        <MudSimpleTable Elevation="2" Dense="true" Hover="true">
            <thead>
                <tr>
                    <th>Job Name</th>
                    <th>Last Event Time</th>
                    <th>Last Scheduled Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in _jobs)
                {
                    <tr>
                        <td>@job.JobName</td>
                        <td>@(job.JobEventTime?.LocalDateTime.ToString("G") ?? "-")</td>
                        <td>@(job.JobScheduledTime?.LocalDateTime.ToString("G") ?? "-")</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    [Parameter] public string SourceSlug { get; set; } = default!;
    [Parameter] public Guid ConnectionId { get; set; }

    private IDashboardApiClient? Api;
    private bool _sourceError;
    private string? _lastSourceSlug;
    private Guid? _lastConnectionId;

    private List<QueueInfoResponse>? _queues;
    private List<JobResponse>? _jobs;
    private Dictionary<Guid, int> _consumerCounts = new();
    private string? _connectionName;
    private bool _loading = true;
    private string? _error;

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Connections", href: null, disabled: true),
        new BreadcrumbItem("Connection", href: null, disabled: true)
    };

    protected override async Task OnParametersSetAsync()
    {
        // Guard: skip if same slug AND same connection ID
        if (string.Equals(SourceSlug, _lastSourceSlug, StringComparison.Ordinal)
            && ConnectionId == _lastConnectionId)
            return;
        _lastSourceSlug = SourceSlug;
        _lastConnectionId = ConnectionId;

        _sourceError = false;
        try
        {
            Api = MultiSourceClient.GetClientForSource(SourceSlug);
        }
        catch (KeyNotFoundException)
        {
            _sourceError = true;
            _loading = false;
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        if (Api == null) return;

        _loading = true;
        _error = null;
        try
        {
            var connectionsTask = Api.GetConnectionsAsync();
            var queuesTask = Api.GetQueuesAsync(ConnectionId);
            var jobsTask = Api.GetJobsAsync(ConnectionId);
            var consumersTask = Api.GetConsumerCountsAsync();
            var connections = await connectionsTask;
            _connectionName = connections.FirstOrDefault(c => c.Id == ConnectionId)?.DisplayName;

            var crumbs = new List<BreadcrumbItem>();
            var sources = SourceRegistry.GetAll();
            if (sources.Count > 1)
            {
                var sourceName = SourceRegistry.GetBySlug(SourceSlug)?.Name ?? SourceSlug;
                crumbs.Add(new BreadcrumbItem(sourceName, href: "/"));
            }
            crumbs.Add(new BreadcrumbItem("Connections", href: $"/source/{SourceSlug}"));
            crumbs.Add(new BreadcrumbItem(_connectionName ?? "Connection", href: null, disabled: true));
            _breadcrumbs = crumbs;

            _queues = await queuesTask;
            _jobs = await jobsTask;
            _consumerCounts = await consumersTask;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetConsumerCount(Guid queueId)
    {
        return _consumerCounts.TryGetValue(queueId, out var count) ? count : 0;
    }

    private void NavigateToQueue(QueueInfoResponse queue)
    {
        var connName = Uri.EscapeDataString(_connectionName ?? "Connection");
        var queueName = Uri.EscapeDataString(queue.QueueName ?? "Queue");
        Navigation.NavigateTo($"/source/{SourceSlug}/queues/{queue.Id}?conn={connName}&connId={ConnectionId}&queue={queueName}");
    }
}
